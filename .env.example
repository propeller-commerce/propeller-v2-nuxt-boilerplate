# Server-only (never sent to client). Mirrors propeller-next + propeller-vue.
BOILERPLATE_GRAPHQL_ENDPOINT=https://api.staging.helice.cloud/v2/graphql
BOILERPLATE_API_KEY=
BOILERPLATE_ORDER_EDITOR_API_KEY=
BOILERPLATE_PORTAL_MODE=open
BOILERPLATE_DEFAULT_LANGUAGE=NL
BOILERPLATE_CURRENCY=€
REVALIDATE_SECRET=
BASE_CATEGORY_ID=1324
CHANNEL_ID=621

# Exposed to client via runtimeConfig.public
NUXT_PUBLIC_GRAPHQL_ENDPOINT=/api/graphql
NUXT_PUBLIC_SITE_URL=
NUXT_PUBLIC_PORTAL_MODE=open
NUXT_PUBLIC_CURRENCY=€
NUXT_PUBLIC_CURRENCY_CODE=EUR
NUXT_PUBLIC_URL_PATTERN=page/id/slug
NUXT_PUBLIC_MENU_DEPTH=3

# ── Machines / spare parts (client-read via runtimeConfig.public) ────────────
# External system the machine ids belong to. The id list comes from the
# contact's company MY_INSTALLATIONS track attribute at runtime (already in
# configuration.companyTrackAttributes). Leave unset to disable the machines
# root. Tree language usually EN while parts stay in the storefront language.
NUXT_PUBLIC_MACHINE_SOURCE=
NUXT_PUBLIC_MACHINE_LANGUAGE=EN

# ── Payments (PSP: Mollie OR MultiSafepay) ───────────────────────────────────
# Pick ONE provider by setting BOTH PAYMENT_PROVIDER (server) and
# NUXT_PUBLIC_PAYMENT_PROVIDER (client) to the SAME value: `mollie` or
# `multisafepay`. Leave them empty to keep the default "place order → straight to
# thank-you" (on-account) behaviour. Only the matching key block below is read.
PAYMENT_PROVIDER=
# Comma-separated payment-method codes that settle on account (no PSP).
ON_ACCOUNT_PAYMENTS=REKENING,ON_ACCOUNT

# — Mollie —
MOLLIE_TEST_KEY=
MOLLIE_LIVE_KEY=
MOLLIE_TEST_MODE=true
# MOLLIE_WEBHOOK_URL=

# — MultiSafepay —
# MSP_TEST_MODE=true → testapi.multisafepay.com + MSP_TEST_KEY; false →
# api.multisafepay.com + MSP_LIVE_KEY.
MSP_TEST_KEY=
MSP_LIVE_KEY=
MSP_TEST_MODE=true
# Optional account metadata (present for parity with next/vue; not read by app).
MSP_WEBSITE_ID=
MSP_SECURITY_CODE=
# Optional MultiSafepay locale (default en_US when empty).
# MSP_LOCALE=en_US

# The PSP can't reach localhost. In dev, start a tunnel (cloudflared / ngrok) to
# the dev server (port 5000). The shopper redirect uses NUXT_PUBLIC_SITE_URL; the
# webhook falls back to it too, or set MOLLIE_WEBHOOK_URL / MSP_WEBHOOK_URL to the
# tunnel's /api/<provider>/webhook explicitly. Re-set per dev session.
# MSP_WEBHOOK_URL=

# Client-visible toggle (mirror the server PAYMENT_PROVIDER above):
NUXT_PUBLIC_PAYMENT_PROVIDER=
NUXT_PUBLIC_ON_ACCOUNT_PAYMENTS=REKENING,ON_ACCOUNT
